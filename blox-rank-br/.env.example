NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false

# PostgreSQL. Use uma credencial exclusiva e com privilégios mínimos.
DATABASE_URL=postgresql://blox_rank_user:change-me@localhost:5432/blox_rank_br
# Obrigatório como true quando NODE_ENV=production.
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_QUERY_TIMEOUT_MS=20000
DATABASE_LOCK_TIMEOUT_MS=5000
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000

# Gere com, por exemplo: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
API_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://localhost:5173,https://seu-site.base44.app
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
REGISTRATION_RATE_LIMIT_MAX=5

DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_APPLICATION_ID=000000000000000000
DISCORD_GUILD_ID=000000000000000000
DISCORD_STAFF_ROLE_ID=000000000000000000
DISCORD_PARTICIPANT_ROLE_ID=000000000000000000
DISCORD_INSCRICOES_CHANNEL_ID=000000000000000000
DISCORD_LOGS_CHANNEL_ID=000000000000000000

OUTBOX_POLL_INTERVAL_MS=3000
