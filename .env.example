# Backend publicado. Informe somente a origem, sem barra final, caminho, query ou credenciais.
API_BASE_URL=https://api.example.com

# Segredos exclusivos do site. Nunca use os valores de exemplo em produção.
API_ADMIN_TOKEN=replace-with-the-backend-api-secret
ADMIN_PASSWORD_HASH=hmac-sha256$replace-with-base64url-hmac
# ID do Discord usado internamente nos registros de auditoria administrativa.
ADMIN_DISCORD_ID=000000000000000000
SESSION_SECRET=replace-with-at-least-32-random-characters

# Endereço canônico final do site.
PUBLIC_SITE_URL=https://www.example.com

# Links públicos opcionais. Deixe vazio enquanto não houver canal oficial.
PUBLIC_DISCORD_URL=
PUBLIC_TIKTOK_URL=
PUBLIC_YOUTUBE_URL=
